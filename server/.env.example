# Copy this file to .env and fill in real values for production. .env is
# gitignored. With no .env file, sensible dev-only defaults are used, so
# local development works with zero setup.

# A long random string, kept secret in production. Generate one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Must be False in production.
DEBUG=False

# Comma-separated list of hostnames/domains this server is allowed to serve.
ALLOWED_HOSTS=yourdomain.com

# Comma-separated list of frontend origins allowed to call this API.
CORS_ALLOWED_ORIGINS=https://yourdomain.com
